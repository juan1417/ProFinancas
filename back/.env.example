# =============================================================
# ProFinancas backend — environment variables
# Copy to `.env` (gitignored) and fill in real values.
# =============================================================

# --- Django core ---
# Generate a fresh one for production: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=django-insecure-replace-me-in-production
DEBUG=True
# Comma-separated list of allowed hosts. Use '*' only in dev.
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (Postgres in production) ---
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Test runner ---
# Set to True to force the in-memory SQLite backend. The pytest
# config in pytest.ini uses ProFinanzas.settings_test instead and
# doesn't need this var.
DJANGO_TESTING=False

# --- Rate limiting (optional overrides) ---
# Default: 10 login attempts/min, 5 register attempts/hour per IP.
# Uncomment to tune.
# THROTTLE_LOGIN=10/min
# THROTTLE_REGISTER=5/hour
